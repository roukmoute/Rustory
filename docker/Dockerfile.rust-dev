# Reproducible Rust + Tauri v2 build environments.
#
# Why these images exist: compiling the `src-tauri` crate requires the GTK /
# WebKitGTK / libsoup / appindicator / rsvg / xdo development headers plus
# `pkg-config`. Installing them on every contributor's host is fragile, so we
# run the native Linux toolchain inside containers instead.
#
# Targets:
# - rust-dev: Rust/Cargo only, used by local verification commands.
# - tauri-dev: rust-dev plus Node/pnpm, used by `tauri dev` over X11.
FROM rust:1.95-bookworm AS rust-tauri-base

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        pkg-config \
        libwebkit2gtk-4.1-dev \
        libjavascriptcoregtk-4.1-dev \
        libglib2.0-dev \
        libgtk-3-dev \
        librsvg2-dev \
        libayatana-appindicator3-dev \
        libxdo-dev \
        libssl-dev \
        build-essential \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# rustfmt + clippy are required by the verify CI lane and by the matching
# local smoke tests (`cargo fmt --check`, `cargo clippy -- -D warnings`).
# Install them into the base image so every `docker compose run` starts
# fully equipped.
RUN rustup component add rustfmt clippy

# Cargo caches mounted as named volumes from docker-compose; pre-creating the
# target directory keeps permissions aligned with the non-root `cargo` user.
WORKDIR /workspace

FROM rust-tauri-base AS rust-dev

FROM node:20-bookworm AS node-runtime

FROM rust-tauri-base AS tauri-dev

# Copy the Node.js toolchain (node + npm) from the official image. We bypass
# corepack because its activation pipeline assumes a writable ~/.cache layout
# that does not survive a cross-stage `COPY --from`.
COPY --from=node-runtime /usr/local /usr/local

ENV PATH="/workspace/node_modules/.bin:${PATH}"

RUN npm install -g pnpm@10.28.2
