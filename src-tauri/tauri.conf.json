{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rustory",
  "version": "0.4.0",
  "identifier": "fr.roukmoute.rustory",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rustory",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; media-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["rustory"],
        "name": "RustoryStory",
        "description": "Histoire Rustory",
        "mimeType": "application/x-rustory",
        "role": "Editor",
        "rank": "Owner",
        "exportedType": {
          "identifier": "fr.roukmoute.rustory.story",
          "conformsTo": ["public.json"]
        }
      }
    ],
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/mime/packages/fr.roukmoute.rustory.xml": "bundle/linux/rustory-mime.xml"
        }
      },
      "deb": {
        "desktopTemplate": "bundle/linux/rustory.desktop",
        "files": {
          "/usr/share/mime/packages/fr.roukmoute.rustory.xml": "bundle/linux/rustory-mime.xml"
        }
      },
      "rpm": {
        "desktopTemplate": "bundle/linux/rustory.desktop",
        "files": {
          "/usr/share/mime/packages/fr.roukmoute.rustory.xml": "bundle/linux/rustory-mime.xml"
        }
      }
    }
  }
}
